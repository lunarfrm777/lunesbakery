---
import Nav from "../components/Nav.astro";
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <Nav />
    <h2>
        &#x131A9;&#x2661;&#x131AA;About Lune's Bakery&#x131A9;&#x2661;&#x131AA;
    </h2>

    <div class="container">
        <p>
            &#x131A9;&#x2661;&#x131AA; Everything is grown right around the
            corner from the bakery which allows for a Knowing of where all the
            products are coming from!!! &#x131A9;&#x2661;&#x131AA;
        </p>

        <p>
            &#x131A9;&#x2661;&#x131AA; This journey all started with the simple
            phrase of "Farmers Feed Cities" and now we have the pleasure,,
            honour and gratitude to be able to feed cities in another way
            through the bakery! &#x131A9;&#x2661;&#x131AA;
        </p>
    </div>
</Layout>
<style>
    h2 {
        text-align: center;
    }

    .container {
        display: grid;
        padding: 1rem;
        gap: 1rem;
        margin: 0 auto;
        background-color: blueviolet;
        width: 33.33%;
        height: 33.33%;
        border-radius: 1rem;
        border: 4px white solid;
    }
</style>
