---
import { Image } from "astro:assets";
const { image, title, alt, width, src } = Astro.props;
---

<a href={src} class="bake-card">
    <div class="style-title">
        <h4>{title}</h4>
    </div>
    <Image src={image} alt={alt} width={200} height={200} />
    <div>
        <a
            class="lemonsqueezy-button"
            href="https://app.lemonsqueezy.com/checkout/lunesbakery.lemonsqueezy.com">
            Buy Now
        </a>
    </div>
</a>
<style>
    .bake-card {
        border: 0.5rem rgb(253, 255, 203) solid;
        border-radius: 0.5rem;
        margin-right: 4px;
        text-decoration: none;
        text-align: center;
        color: black;
    }

    .style-title {
        border: 0.5rem rgb(183, 124, 255) solid;
        background-color: rgb(183, 124, 255);
    }

    h4 {
        border-bottom: 0.5rem rgb(252, 151, 0) solid;
    }
</style>
