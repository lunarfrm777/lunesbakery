---
import { Image } from "astro:assets";
 import { addToCart } from "../scripts/cart.js"
const { image, title, alt, width, src } = Astro.props;
---


<div class="bordered">
  <a href={src} class="bake-card">
    <h4>{title}</h4>
    <Image src={image} alt={alt} width={200} height={200} />
  </a>

  <div class="checkout-button">
    <a class="buy-btn">Buy Now</a>
    <a href="/cart">Checkout</a>
  </div>
</div>


<style>
    .bordered {
        border: 3px white solid;
        border-radius: 0.7rem;
    }

    /* have to improve responsive for cards,, should be a set top middle and bottom so they are sliding with screen size
    rather than clicking into place */
    .bake-card {
        display: grid;
        gap: 1rem;
        background-color: rgb(183, 124, 255);
        border-radius: 0.5rem;
        text-decoration: none;
        text-align: center;
        color: black;
    }

    h4 {
        margin-bottom: 3px;
    }
    .checkout-button {
        padding: 1rem;
        text-decoration: none;
        background-color: pink;
        display: flex;
        justify-content: center;
    }

    a {
        text-decoration: none;
        color: black;
        font-weight: bold;
        text-align: center;
    }
</style>
<script>
  import { addToCart } from "../scripts/cart.js";

  document.querySelectorAll(".buy-btn").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      console.log("clicked");

      addToCart("Cupcake", 5);

      window.location.href = "/cart";
    });
  });
</script>