---
const isRoot = Astro.url.pathname === "/";
---

<header>
        <nav class="navStyle">
            <ul>
                <!-- routes to root -->
                <li><a href="/">Home</a></li>

                <!-- routes to pages/about page -->
                <li><a href="/about">About</a></li>

                <!-- routes to pages/goodies page-->
                <li><a href="/bakes">Baked Goods</a></li>

                <!-- will only show these li's on home page using isRoot set to / -->
                {isRoot && (
            // <!-- scroll down lower on main -->
                <li><a href="#location">Location</a></li>
                <li><a href="#contact">Contact</a></li>
        )}
            </ul>
        </nav>
    </div>
</header>

<style>
    ul {
        list-style-type: none;
        display: flex;
        text-decoration: none;
        padding: 1rem;
    }

    li {
        padding: 8px 16px;
        background-color: rgb(255, 23, 189);
        margin-right: 5px;
    }

    ul li {
        text-decoration: none;
    }
</style>
