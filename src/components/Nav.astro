    <style>
        h2 {
            color: black;
        }
        .nav-style {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 1rem;
            height: 5rem;
            background-color: #ec4899;
            color: white;
        }

        .nav-links {
            display: flex;
            gap: 1rem;
            list-style: none; /* removes bullets */
            margin: 0;
            padding: 0;
        }

        span {
            color: black;
            font-weight: bold;
        }

        .nav-links li {
            list-style: none;
        }

        ul {
            list-style-type: none;
            display: flex;
            padding: 1rem;
            justify-content: center;
        }

        li {
            padding: 1rem 1rem;
            margin-right: 5px;
        }

        a {
            text-decoration: none;
            color: rgb(0, 0, 0);
            font-weight: bold;
        }

        .cart-styling {
            color: black;
        }
    </style>
    <script type="module">
        const menu = document.getElementById("nav-mobile");
        const btn = document.getElementById("burger-btn"); // if using a button elsewhere

        // toggle menu when burger clicked
        if (btn) {
            btn.addEventListener("click", () => {
                menu.classList.toggle("open");
            });
        }

        // close menu when clicking a link
        if (menu) {
            menu.querySelectorAll("a").forEach((link) => {
                link.addEventListener("click", () => {
                    menu.classList.remove("open");
                });
            });
        }

        // close when clicking outside links (anywhere on menu)
        menu.addEventListener("click", (e) => {
            // only close if user clicks the background, not the links themselves
            if (e.target === menu) {
                menu.classList.remove("open");
            }
        });
</script>