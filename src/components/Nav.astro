---
const isRoot = Astro.url.pathname === "/";
const links = ['Home', 'About', 'Baked Goods', 'Location', 'Contact']
import Cart from "../components/Cart.jsx";
---

<nav class="flex justify-between items-center w-full h-20 px-4 text-white bg-pink-500">
  <h1 class="text-5xl font-signature">♡ Lune ♡</h1>

  <ul class="hidden md:flex">
    {links.map((link) => (
      <li class="px-4 capitalize">
        <a href={`#${link}`}>{link}</a>
      </li>
    ))}
  </ul>
</nav>
<header>
        <nav class="navStyle">
            <ul>
                <!-- routes to root -->
                <li><a href="/">Home</a></li>

                <!-- routes to pages/about page -->
                <li><a href="/about">About</a></li>

                <!-- routes to pages/goodies page-->
                <li><a href="/bakes">Baked Goods</a></li>

                <!-- will only show these li's on home page using isRoot set to / -->
                {isRoot && (
            // <!-- scroll down lower on main -->
                <li><a href="#location">Location</a></li>
                <li><a href="#contact">Contact</a></li>
        )}

                <Cart client:load />

                <li><a href="/cart">🛒 Cart (<span id="cart-count">0</span>)</a></li>
            </ul>
        </nav>
    </div>
</header>

<style>
    ul {
        list-style-type: none;
        display: flex;
        padding: 1rem;
        justify-content: center;
    }

    li {
        padding: 8px 16px;
        background-color: rgb(253, 144, 222);
        margin-right: 5px;
    }

    a {
        text-decoration: none;
        color: rgb(0, 0, 0);
        font-weight: bold;
    }
</style>
