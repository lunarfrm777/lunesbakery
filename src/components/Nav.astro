---
const isRoot = Astro.url.pathname === "/";
import NavStyle from "./NavStyle.astro";
import MobileMenu from "./MobileMenu.astro";
---
<header class="main-header">
    <!-- <a href="/"><img src="/Logo.png" class="logo" /></a> -->

    <NavStyle />

    <!-- ONLY this -->
    <label for="check" class="checkbtn" id="burger-btn">
        <i class="fa-solid fa-burger"></i>
    </label>
</header>

<!-- mobile menu lives OUTSIDE -->
<MobileMenu />
    <style>
        h2 {
            color: black;
        }
        
        .main-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .nav-style {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 1rem;
            height: 5rem;
            background-color: #ffa3d1;
            color: white;
        }

        .nav-links {
            display: flex;
            gap: 1rem;
            list-style: none; /* removes bullets */
            margin: 0;
            padding: 0;
        }

        span {
            color: black;
            font-weight: bold;
        }

        .nav-links li {
            list-style: none;
        }

        ul {
            list-style-type: none;
            display: flex;
            padding: 1rem;
            justify-content: center;
        }

        li {
            padding: 1rem 1rem;
            margin-right: 5px;
        }

        a {
            text-decoration: none;
            color: rgb(0, 0, 0);
            font-weight: bold;
        }

        .cart-styling {
            color: rgb(255, 255, 255);
        }
         .checkbtn,
        #burgerbtn {
        display: none;
        cursor: pointer;
        }

        i {
            color: white;
        }
    @media screen and (max-width: 625px) {
        .checkbtn {
            display: block;
        }
    }
    </style>
    <script type="module">
        const menu = document.getElementById("nav-mobile");
        const btn = document.getElementById("burger-btn"); // if using a button elsewhere

        // toggle menu when burger clicked
        if (btn) {
            btn.addEventListener("click", () => {
                menu.classList.toggle("open");
            });
        }

        // close menu when clicking a link
        if (menu) {
            menu.querySelectorAll("a").forEach((link) => {
                link.addEventListener("click", () => {
                    menu.classList.remove("open");
                });
            });
        }

        // close when clicking outside links (anywhere on menu)
        menu.addEventListener("click", (e) => {
             if (!e.target.closest("a")) {
                menu.classList.remove("open");
            }
        });
</script>