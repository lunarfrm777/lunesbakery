---
import BakeCard from "../components/BakeCard.astro";
import bb from "/images/BakedGoods/TodayBakes/bb.jpg";
import cc from "/images/BakedGoods/TodayBakes/cc.png";
import mc from "/images/BakedGoods/TodayBakes/mc.jpg";

const bakes = [
    {
        image: bb,
        title: "Blueberry Pastry",
        alt: "Blueberry Pastry",
        src: "/bakes",
    },
    {
        image: cc,
        title: "Chocolate Croissant",
        alt: "Chocolate Croissant",
        src: "/bakes",
    },
    {
        image: mc,
        title: "Macadamia Nut Cookie",
        alt: "Macadamia Nut Cookie",
        src: "/bakes",
    },
];
---

<h2>
    &#x131A9;&#x2661;&#x131AA; Today's Fresh Bakes &#x131A9;&#x2661;&#x131AA;
</h2>

<div class="container">
    {bakes.map((bake) => <BakeCard {...bake} />)}
</div>

<style>
    .container {
        display: flex;
        grid-template-columns: repeat(auto-fill, minmax (200px, 1fr));
        gap: 1rem;
        margin: 0 auto;
        justify-content: center;
        padding: 1.5rem;
    }

    h2 {
        text-align: center;
    }
</style>
