---
import bb from "../assets/BakedGoods/TodayBakes/bb.jpg";
import cc from "../assets/BakedGoods/TodayBakes/cc.png";
import mc from "../assets/BakedGoods/TodayBakes/mc.jpg";
import BakeCard from "../layouts/BakeCard.astro";
---

<h2>
    &#x131A9;&#x2661;&#x131AA; Today's Fresh Bakes &#x131A9;&#x2661;&#x131AA;
</h2>

<div class="container">
    <BakeCard image={bb} alt="Blueberry Pastry" width={200} />

    <BakeCard image={cc} alt="Chocolate Croissant" width={200} />

    <BakeCard image={mc} alt="Macadamian Nut Cookie" width={200} />
</div>

<style>
    .container {
        display: flex;
        flex-direction: row;
        margin: 0 auto;
    }
</style>
