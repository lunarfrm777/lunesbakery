---
import BakeCard from "../components/BakeCard.astro";

const bakes = [
    {
        image: "/images/BakedGoods/bagel.jpg",
        title: "Everything Bagel",
        alt: "Everything Bagel",
        src: "/bakes",
    },
    {
        image: "/images/BakedGoods/bread.jpg",
        title: "White Bread",
        alt: "White Bread",
        src: "/bakes",
    },
    {
        image: "/images/BakedGoods/cc-m.jpg",
        title: "Chocolate Chip Muffins",
        alt: "Chocolate Chip Muffins",
        src: "/bakes",
    },
];
---
<section>
    <h2>&#x131A9;&#x2661;&#x131AA; Daily Regulars &#x131A9;&#x2661;&#x131AA;</h2>
        <div class="container">
            {bakes.map((bake) => <BakeCard {...bake} />)}
        </div>
</section>

<style>
  .container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    justify-items: center;
    justify-content: center;
    padding: 0.5rem;
    max-width: 1000px;
    margin: 2rem auto;
}

.container > * {
  display: flex;
}
    h2 {
        text-align: center;
    }
</style>
