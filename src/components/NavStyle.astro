<header class="main-header">
    <!-- desktop links -->
   <nav class="nav-links-container">
        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/bakes">Baked Goods</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><span class="nav-total">$0</span></li>
            <li>
                <a class="cart-styling" href="/checkout"
                    >🛒 Cart (<span class="cart-count">0</span>)</a
                >
            </li>
        </ul>
    </nav>
</header>

<style>
    :global(*) {
        box-sizing: border-box;
    }

    .main-header {
        display: flex;
        justify-content: end;
        align-items: center;
        padding: 1rem;
        width: 100%;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        overflow: auto;
        position: relative;
    }

    h2 a {
        text-decoration: none;
    }

    .nav-links-container {
        display: flex;
        align-items: center;
        margin-left: auto;
        gap: 2rem;
    }

    /* nav links horizontal list */
    .nav-links {
        display: flex;
        gap: 2rem;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    /* individual link style + hover underline */
    .nav-links a, span {
        position: relative;
        text-decoration: none;
        font-weight: bold;
        color: #fc1547;
        transition: color 0.3s ease;
        font-family: "Jost", sans-serif;
        font-size: 14px;
    }

    .nav-links a::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -4px;
        width: 0%;
        height: 2px;
        background: rgb(255, 120, 235);
        transition: width 0.3s ease;
    }

    .nav-links a:hover {
        color: black;
    }

    .nav-links a:hover::after {
        width: 100%;
    }

    @media screen and (max-width: 625px) {
        .nav-links-container {
            display: none;
        }
    }
</style>

<script type="module">
    // ✅ Step 3: Update it when cart changes

    // Right now:
    // You update the cart
    // But your nav doesn’t know it changed

// So after addToCart() and removeItem():
 import { updateCartCount, getCartTotal } from "../scripts/cart.js"
    window.addEventListener("load", () => {
    const navTotalEl = document.querySelectorAll(".nav-total");

  console.log("FOUND:", navTotalEl); // debug

  function updateNavTotal() {
    if (!navTotalEl) return;

    const total = getCartTotal();
    navTotalEl.textContent = `${total.toFixed(2)}`;
  }

// Initial call = “render what already exists now”
updateCartCount();
updateNavTotal();

    // updating getCart() (product items)
    // updating getCartTotal ($ amount)
   window.addEventListener("cart-updated", () => {
  updateCartCount();   // uses getCart()
  updateNavTotal();    // uses getCartTotal()
});
    //   storage across tabs!
  window.addEventListener("storage", () => {
    updateCartCount()
    updateNavTotal()
  });
  });
</script>