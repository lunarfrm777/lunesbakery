---
import Location from "./Location.astro";
import Socials from "./Socials.astro";
---

<div class="container">
    <section>
        <h2>♡ Contact Lune's Bakery ♡</h2>

        <p>♡ Telephone:: 905-777-7777 ♡</p>

        <p>♡ lunesbakery@stargirl.com ♡</p>

        <h3>Address: 123 Dreamland Road</h3>

        <h4>Business Hours:</h4>
        <ul>
            <li>Monday to Friday: 8:00AM - 6:00 PM</li>
            <li>Saturday : 8:00 AM - 5:00 PM</li>
            <li>Sunday : 8:00 AM - 4:00 PM</li>
        </ul>
    
    </section>
    <Location />
    <Socials />
</div>

<style>
    .container {
        text-align: center;
        padding: 2rem;
        background: linear-gradient(
      to right,
      rgba(16, 180, 10, 0.8) 0%,
      rgba(167, 81, 204, 0.8) 96%
    );
    }

    li {
        text-decoration: none;
        list-style-type: none;
        margin-top: .5rem;
    }
</style>
