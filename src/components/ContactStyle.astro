---
import Location from "./Location.astro";
---
<div class="container">
        <h2>&#x131A9;&#x2661;&#x131AA; Contact &#x131A9;&#x2661;&#x131AA;</h2>
        <form action="https://api.web3forms.com/submit" method="POST" class="form-container">
            <section class="bakery-info">
                <p>&#x131A9;&#x2661;&#x131AA; Telephone: 905-777-7777 &#x131A9;&#x2661;&#x131AA;</p>
                <p>&#x131A9;&#x2661;&#x131AA; Address: 123 Dreamland Road &#x131A9;&#x2661;&#x131AA;</p>
            </section>
        <input type="hidden" name="access_key" value="ddd37b81-2574-4b9b-a2aa-4bd9ec129b0e">
        <div class="form-row">
            <label for="name">Name:</label>
            <input id="name" type="text" />
        </div>

        <div class="form-row">
            <label for="email">Email:</label>
            <input id="email" type="email" />
        </div>

        <div class="form-row">
            <label for="message">Message:</label>
            <textarea id="message"></textarea>
        </div>
        <button type="submit">Submit</button>
    </form>
    <Location />
</div>

<style>
    .container {
        display: flex;
        flex-direction: column;
        text-align: center;
        padding: 2rem;
        background-color: pink;
        justify-content: center;
        align-items: center;
    }

    li {
        text-decoration: none;
        list-style-type: none;
        margin-top: .5rem;
    }

    .form-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1rem;
          width: 100%;
        max-width: 500px;
        box-shadow:
            0 4px 15px rgba(0, 0, 0, 0.15),
            0 10px 30px rgba(0, 0, 0, 0.2);
        overflow: hidden;
        border-radius: 4px;
        background-color: rgb(255, 125, 255);
    }
    form {
        display: flex;
        gap: 1rem;
        flex-direction: column;
    }
    
    .form-row {
        display: flex;
         align-items: center;
        gap: 1rem;
        width: 100%;
    }

    label {
        width: 100px; /* fixed label width = aligned */
        }

    input,textarea {
        width: 100%;
        box-sizing: border-box; /* take remaining space */
        }       

    textarea {
        width: 100%;
        min-height: 100px;
        max-height: 300px; /* prevents infinite growth */
        resize: none; /* disables manual dragging */
        overflow-y: hidden; /* hides scrollbar */
    }

    button {
      border-radius: 1rem; 
      background-color: hotpink;
    }

    button:hover {
      background-color: rgb(251, 73, 102);
      color: black;
    }

    label, button {
        font-weight: bold;
    }

    .bakery-info {
        padding: 1rem;
        font-weight: bold;
    }
    
    @media (min-width: 600px) {
        .form-row {
            flex-direction: row;
            align-items: center;
        }

        label {
            width: 100px;
        }
}
</style>

<script>
    document.querySelectorAll("textarea").forEach((ta) => {
  ta.addEventListener("input", () => {
    ta.style.height = "auto"; // reset
    ta.style.height = ta.scrollHeight + "px"; // grow to fit content
  });
});
</script>