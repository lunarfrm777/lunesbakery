---
import Location from "./Location.astro";
import Socials from "./Socials.astro";
---
<form class="form-container">
  <div class="form-row">
    <label for="name">Name:</label>
    <input id="name" type="text" />
  </div>

  <div class="form-row">
    <label for="email">Email:</label>
    <input id="email" type="email" />
  </div>

  <div class="form-row">
    <label for="message">Message:</label>
    <textarea id="message"></textarea>
  </div>
</form>
<div class="container">
    <h2>&#x131A9;&#x2661;&#x131AA; Contact &#x131A9;&#x2661;&#x131AA;</h2>
    <div class="form-container">
     <form action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="ddd37b81-2574-4b9b-a2aa-4bd9ec129b0e">
        <label for="name">Name:</label>
        <input type="text" name="name" required> 
        <label for="email">Email:</label>
        <input type="email" name="email" required>
        <label for="email">Message:</label>
        <textarea name="message" required></textarea>
        <button type="submit">Submit</button>
        </form>
    </div>
    <Location />
    <Socials />
</div>

<style>
    .container {
        display: flex;
        flex-direction: column;
        text-align: center;
        padding: 2rem;
        background-color: pink;
        justify-content: center;
        align-items: center;
    }

    li {
        text-decoration: none;
        list-style-type: none;
        margin-top: .5rem;
    }

    .form-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        width: 33.33%;
        box-shadow:
            0 4px 15px rgba(0, 0, 0, 0.15),
            0 10px 30px rgba(0, 0, 0, 0.2);
        overflow: hidden;
        border-radius: 4px;
        background-color: rgb(255, 125, 255);
    }
    form {
        display: flex;
        width: 33.33%;
        gap: 1rem;
        flex-direction: column;
    }

    textarea {
        width: 100%;
        min-height: 100px;
        max-height: 300px; /* prevents infinite growth */
        resize: none; /* disables manual dragging */
        overflow-y: hidden; /* hides scrollbar */
    }
</style>

<script>
    document.querySelectorAll("textarea").forEach((ta) => {
  ta.addEventListener("input", () => {
    ta.style.height = "auto"; // reset
    ta.style.height = ta.scrollHeight + "px"; // grow to fit content
  });
});
</script>