---
import { Image } from "astro:assets";
import BakeryPhoto from "../../public/images/BakeryLocation.png";
---

<div class="location-styling">
        <h2>&#x131A9;&#x2661;&#x131AA; Location &#x131A9;&#x2661;&#x131AA;</h2>

        <section class="container">
            <Image
                src={BakeryPhoto}
                alt="Location of Lune's Bakery and Lune's Farm"
                class="location"
            />
    </section>
</div>

<style>
    .location-styling {
        padding: 1rem;
        /* background: linear-gradient(
      to right,
      rgb(237, 242, 85) 0%,
      rgb(255, 163, 65) 96%
    ); */
    }
    .container {
        display: flex;
        justify-content: center;
        padding: 1.5rem;
    }

    .location {
        width: 50%;
        height: 50%;
    }

    h2 {
        text-align: center;
    }
</style>
